{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": "# EV fleet (explicit process/product) using Flodym directly"
    },
    {
      "source": "This notebook follows the same dynamic-stock setup as the normal EV fleet notebook, but places cohort timing on the explicit production edge (`fleet_driving_process -> fleet_driving_product`) instead of an intermediate node."
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": "import numpy as np\nimport bw2data as bd\nfrom bw_timex import TimexLCA\nfrom bw_temporalis import TemporalDistribution\nfrom flodym import Dimension, DimensionSet, StockArray, StockDrivenDSM, WeibullLifetime"
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": "## 1) Build dMFA with Flodym (same pattern as normal fleet notebook)"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": "years = np.arange(2015, 2056)\n\n# Example stock trajectory; replace with your scenario input if needed\nK = 45_000_000\nr = 0.22\nt0 = 2032\nstock_values = K / (1 + np.exp(-r * (years - t0)))\n\ndim_t = Dimension(name=\"time\", letter=\"t\", items=years)\ndims = DimensionSet([dim_t])\nstock = StockArray(dims=dims, values=stock_values)\n\nlifetime_model = WeibullLifetime(dims=dims)\nlifetime_model.set_prms(\n    weibull_shape=np.full(dims.shape, 5.0),\n    weibull_scale=np.full(dims.shape, 14.0),\n)\n\ndsm = StockDrivenDSM(dims=dims, stock=stock, lifetime_model=lifetime_model)\ndsm.compute()\n\ninflow_values = dsm.inflow.values\noutflow_values = dsm.outflow.values"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": "ANALYSIS_START = 2020\nANALYSIS_END = 2050\nFU_YEAR = 2035\n\nmask = (years >= ANALYSIS_START) & (years <= ANALYSIS_END)\nyears_window = years[mask]\ninflow_window = inflow_values[mask]\n\n# Cohort TD from Flodym inflow\ncohort_offsets = (years_window - FU_YEAR).astype(\"timedelta64[Y]\")\ncohort_shares = inflow_window / inflow_window.sum()\ntd_cohort_inflow = TemporalDistribution(date=cohort_offsets, amount=cohort_shares)\n\n# Age TDs from Weibull survival/pdf\nage_years = np.arange(0, 41)\nage_offsets = age_years.astype(\"timedelta64[Y]\")\nsurvival = lifetime_model.sf_by_age_cohort()[0, :len(age_years)]\nretirement = lifetime_model.pdf_by_age_cohort()[0, :len(age_years)]\n\n# Drop exact zeros to avoid empty timeline branches\nuse_mask = survival > 0\nret_mask = retirement > 0\ntd_use_age = TemporalDistribution(date=age_offsets[use_mask], amount=survival[use_mask] / survival[use_mask].sum())\ntd_retirement_age = TemporalDistribution(date=age_offsets[ret_mask], amount=retirement[ret_mask] / retirement[ret_mask].sum())"
    },
    {
      "source": "## 2) Explicit process/product foreground wiring"
      "metadata": {},
      "execution_count": null,
      "outputs": [],
      "source": "fg = bd.Database(\"foreground\")\nfleet_process = fg.new_node(code=\"fleet_driving_process_explicit\", name=\"fleet driving process (explicit)\", unit=\"vkm\")\nfleet_process.save()\nfleet_product = fg.new_node(code=\"fleet_driving_product_explicit\", name=\"fleet driving product (explicit)\", unit=\"vkm\", type=\"product\")\nfleet_product.save()\n\n# Cohort timing now lives on explicit production edge\nfleet_process.new_edge(input=fleet_product, amount=inflow_window.sum(), type=\"production\", temporal_distribution=td_cohort_inflow).save()"
      "source": "electricity = bd.get_node(database=\"background_2020\", code=\"electricity\")\nused_ev = bd.get_node(database=\"foreground\", code=\"used_ev\")\nev_production = bd.get_node(database=\"foreground\", code=\"ev_production\")\n\n# Age-resolved use and retirement timing from Flodym lifetime model\nexc_el = fleet_process.new_edge(input=electricity, amount=1.0, type=\"technosphere\", temporal_distribution=td_use_age)\nexc_el[\"temporal_evolution_factors\"] = {int(y): float(v) for y, v in zip(years_window, np.linspace(1.0, 1.3, len(years_window)))}\nexc_el[\"temporal_evolution_reference\"] = \"consumer\"\nexc_el.save()\n\nfleet_process.new_edge(input=ev_production, amount=1.0, type=\"technosphere\", temporal_distribution=td_use_age).save()\nfleet_process.new_edge(input=used_ev, amount=1.0, type=\"technosphere\", temporal_distribution=td_retirement_age).save()"
      "source": "## 3) Run Timex LCA on fleet product FU"
      "source": "method = (\"IPCC 2021\", \"climate change\", \"global warming potential (GWP100)\")\ndatabase_dates = {\"background_2020\": \"2020\", \"background_2040\": \"2040\", \"foreground\": \"dynamic\"}\n\ntlca = TimexLCA({fleet_product: 1}, method, database_dates)\ntlca.build_timeline(starting_datetime=f\"{FU_YEAR}-01-01\", temporal_grouping=\"year\")\ntlca.lci()\ntlca.dynamic_lcia()\nprint(f\"Dynamic score: {tlca.dynamic_score:,.0f}\")\ntlca.timeline.head()"
